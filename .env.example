# ──────────────────────────────────────────────────────────
# EYAN - Variables de entorno
# Copia este archivo a .env.local (dev) o configúralas en
# Vercel Dashboard → Settings → Environment Variables (prod)
# ──────────────────────────────────────────────────────────

# ─── Base de datos ────────────────────────────────────────
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/eyan?retryWrites=true&w=majority

# ─── NextAuth ─────────────────────────────────────────────
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=
# Dev: http://localhost:3000 · Prod: https://tu-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ─── Salesforce (Dos Pinos sync) ──────────────────────────
# SOLO requeridas en máquinas que corren scrapers (local).
# En Vercel no son necesarias (scrapers deshabilitados serverless).
SF_ORG_URL=
SF_USERNAME=
SF_PASSWORD=
SF_REPORT_NAME=
SF_REPORT_URL=

# ─── Factura en la Nube (FEN) ─────────────────────────────
# Igual: solo en máquinas con scrapers.
FEN_BASE_URL=https://app.facturaenlanube.com
FEN_USERNAME=
FEN_PASSWORD=

# ─── QuickBooks Online ────────────────────────────────────
# Dev: http://localhost:3000/api/qbo/callback
# Prod: https://tu-app.vercel.app/api/qbo/callback
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox
# Callback real: /api/contabilidad/qbo/callback (configúralo igual en Intuit Developer)

# Gastos de empresa → QBO (Purchase = "Gastos" en la UI)
# QBO_EXPENSE_TXN_TYPE=purchase
# QBO_EXPENSE_PAYMENT_TYPE=Cash
# QBO_EXPENSE_CATEGORY_ACCOUNT_ID=
# QBO_EXPENSE_PAYMENT_ACCOUNT_ID=

# ─── Flags opcionales ─────────────────────────────────────
# Forzar habilitación de scrapers (solo si tienes Chromium instalado).
# ALLOW_SCRAPERS=true
